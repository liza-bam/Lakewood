{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bebas Neue|Inter))/i]",
        "message": "Font not provided by the design system. Available: Bebas Neue, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|defaultOpen|style|key|ref|className|style|children)$/]",
        "message": "<Accordion> doesn't accept that prop. Declared props: items, defaultOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|href|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<ArrowLink> doesn't accept that prop. Declared props: color, href, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowLink'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:navy|ember|brown|inverse)$/]",
        "message": "<ArrowLink> color must be one of 'navy' | 'ember' | 'brown' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|arrow|href|onClick|disabled|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, arrow, href, onClick, disabled, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|brown|pine|outline|inverse)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'brown' | 'pine' | 'outline' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|as|style|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: color, as, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:ember|pine|brown|quiet|inverse)$/]",
        "message": "<Eyebrow> color must be one of 'ember' | 'pine' | 'brown' | 'quiet' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|type|placeholder|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, type, placeholder, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|label|title|description|variant|aspect|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PhotoCard> doesn't accept that prop. Declared props: image, label, title, description, variant, aspect, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:card|overlay)$/]",
        "message": "<PhotoCard> variant must be one of 'card' | 'overlay'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|name|detail|style|key|ref|className|style|children)$/]",
        "message": "<ReviewCard> doesn't accept that prop. Declared props: quote, name, detail, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|value|onChange|placeholder|style|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, value, onChange, placeholder, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:links|onNavigate|onReserve|logoSrc|style|key|ref|className|style|children)$/]",
        "message": "<SiteFooter> doesn't accept that prop. Declared props: links, onNavigate, onReserve, logoSrc, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:links|active|onNavigate|onReserve|logoSrc|sticky|style|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: links, active, onNavigate, onReserve, logoSrc, sticky, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
